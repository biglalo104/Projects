        "def is_holiday(x):\n",
        "\n",
        "  india_holidays = holidays.country_holidays('IN')\n",
        "\n",
        "  if india_holidays.get(x):\n",
        "    return 1\n",
        "  else:\n",
        "    return 0\n",
        "df['holidays'] = df['datetime'].dt.date.apply(is_holiday)\n",
